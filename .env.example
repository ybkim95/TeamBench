# TeamBench environment variables — copy to `.env` and fill in the values you need.
# The harness reads these from the process environment AND from a local .env file at the repo root.
# Do NOT commit the .env file itself (it is gitignored).

# === Provider API keys ===
# Set the keys for whichever providers you intend to evaluate. Each key is optional;
# attempting to run a model whose key is missing will fail with a clear error.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# For rotating across multiple Gemini keys to dodge per-key rate limits, you may
# also define GEMINI_API_KEY_2, GEMINI_API_KEY_3, ... The Gemini adapter reads them
# all and round-robins.
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=

# Routing third-party models through OpenRouter (any model behind `--model openrouter:...`)
OPENROUTER_API=

# === vLLM / self-hosted OpenAI-compatible endpoints ===
# Only needed when you use `--model vllm:<name>` or `--base-url http://...` with the
# OpenAI-compatible flow. Defaults shown.
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MAX_TOKENS=8192
# VLLM_CONTEXT_WINDOW=32768

# === Hugging Face ===
# Optional. Needed if you want to push artifacts (dataset cards, Space updates) from
# your own workflow. Read scope alone is enough for `datasets.load_dataset`.
# HF_TOKEN=
